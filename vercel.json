{
  "outputDirectory": "public",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    { "src": "/api/data",  "dest": "/api/data.js"  },
    { "src": "/api/save",  "dest": "/api/save.js"  },
    { "src": "/admin",     "dest": "/admin.html"   },
    { "src": "/(.*)",      "dest": "/$1"           }
  ]
}
