# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub

# From Supabase → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# From Supabase → Project Settings → API → anon public key
SUPABASE_ANON_KEY=eyJ...your_anon_key

# From Supabase → Project Settings → API → service_role secret key
SUPABASE_SERVICE_KEY=eyJ...your_service_role_key

# Choose any 4-digit number — this is what you type in admin.html to publish
ADMIN_PIN=1234
