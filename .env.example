# ══════════════════════════════════════════════════════
#  APEX TRANSIT — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to git.
# ══════════════════════════════════════════════════════

# From Supabase → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJ...your_anon_public_key
SUPABASE_SERVICE_KEY=eyJ...your_service_role_secret_key

# Admin PIN — must match the ADMIN_PIN in public/admin.html
# Choose any 4-digit code. This env var enforces it server-side.
ADMIN_PIN=1234
